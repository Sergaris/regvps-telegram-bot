# Reg.ru CloudVPS (тот же токен, что в curl Authorization: Bearer …)
REGRU_CLOUDVPS_TOKEN=
# ID reglet в URL/панели, например 62974612
REGRU_REGLET_ID=

# Telegram: токен бота; allowlist — числовые user_id через запятую (id1,id2,…; после запятой может быть пробел)
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USER_IDS=123456789,999888777

# Опционально:
# REGRU_CLOUDVPS_API_BASE=https://api.cloudvps.reg.ru/v1
# HTTP_REQUEST_TIMEOUT_SEC=30

# SSH к хосту Minecraft для команд mcops (/mc_*, /stack_*). Если не задано — эти команды отключены.
# MCOPS_SSH_HOST=203.0.113.10
# MCOPS_SSH_USER=minecraft-ops
# MCOPS_SSH_IDENTITY_FILE=%USERPROFILE%\.ssh\minecraft_ops
# MCOPS_SSH_PORT=22
# MCOPS_SSH_REMOTE_CWD=/opt/minecraft/ops
# MCOPS_SSH_REMOTE_PYTHON=python3
